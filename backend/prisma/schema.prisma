generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  fullName      String
  email         String   @unique
  mobile        String?
  password      String
  role          String   @default("STUDENT")
  isVerified    Boolean  @default(false)
  googleId      String?
  avatar        String?
  refreshToken  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions       Session[]
  otps           Otp[]
  passwordResets PasswordReset[]
  profile        Profile?
  resumes        Resume[]
  chats          Chat[]
  recommendations Recommendation[]
  roadmaps       Roadmap[]
  interviews     Interview[]
  notifications  Notification[]
  loginHistory   LoginHistory[]
  securityLogs   SecurityLog[]
  skillProgress  SkillProgress[]
  skillGaps      SkillGap[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  device    String?
  ip        String?
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  type      String   // VERIFY_EMAIL, RESET_PASSWORD
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  device    String?
  ip        String?
  userAgent String?
  location  String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SecurityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  id               String   @id @default(uuid())
  userId           String   @unique
  bio              String?
  education        String?
  institution      String?
  graduationYear   Int?
  experience       String?
  currentCompany   String?
  currentPosition  String?
  linkedin         String?
  github           String?
  portfolio        String?
  preferredCompanies String?
  preferredDomains String?
  careerGoals      String?
  interests        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  skills           Skill[]
  certifications   Certification[]
  projects         Project[]
  internships      Internship[]
}

model Skill {
  id         String   @id @default(uuid())
  profileId  String
  name       String
  category   String?  // TECHNICAL, SOFT, DOMAIN
  level      String?  // BEGINNER, INTERMEDIATE, ADVANCED, EXPERT
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  progress   SkillProgress[]
}

model SkillProgress {
  id        String   @id @default(uuid())
  skillId   String
  userId    String
  status    String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  progress  Int      @default(0)
  updatedAt DateTime @updatedAt
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([skillId, userId])
}

model Certification {
  id           String   @id @default(uuid())
  profileId    String
  name         String
  issuer       String?
  issueDate    DateTime?
  expiryDate   DateTime?
  credentialId String?
  url          String?
  createdAt    DateTime @default(now())
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(uuid())
  profileId   String
  title       String
  description String?
  technologies String?
  url         String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Internship {
  id          String   @id @default(uuid())
  profileId   String
  company     String
  position    String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  skills      String?
  createdAt   DateTime @default(now())
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Resume {
  id          String   @id @default(uuid())
  userId      String
  fileName    String
  filePath    String
  fileType    String   // PDF, DOCX
  parsedData  String?  // JSON string of parsed data
  resumeScore Int?
  atsScore    Int?
  careerReadiness Int?
  employabilityScore Int?
  strengths   String?  // JSON array
  weaknesses  String?  // JSON array
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Career {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String?
  salaryRange String?
  demandLevel String?  // HIGH, MEDIUM, LOW
  growthPotential String?
  requiredSkills String? // JSON array
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MarketInsight {
  id             String   @id @default(uuid())
  skill          String?
  title          String?
  category       String   // TRENDING_SKILL, FUTURE_SKILL, SALARY_TREND, INDUSTRY_DEMAND, HIRING_TREND, EMERGING_TECH, TOP_COMPANY
  value          String?
  trend          String?  // UP, DOWN, STABLE
  percentage     Float?
  description    String?
  source         String?
  validUntil     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Recommendation {
  id               String   @id @default(uuid())
  userId           String
  careerTitle      String
  matchPercentage  Float
  confidenceScore  Float
  salaryInsights   String?  // JSON
  industryDemand   String?
  growthPotential  String?
  requiredSkills   String?  // JSON array
  reasons          String?  // JSON array - why generated
  influencingSkills String? // JSON array
  influencingGoals String?  // JSON array
  isVerified       Boolean  @default(false)
  verificationSource String?
  isAccepted       Boolean?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SkillGap {
  id             String   @id @default(uuid())
  userId         String
  skillName      String
  currentLevel   String?
  requiredLevel  String?
  gap            Int?
  priority       String?  // CRITICAL, RECOMMENDED, OPTIONAL
  category       String?
  isBeingAddressed Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Roadmap {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  careerGoal  String?
  duration    String?
  learningSpeed String?  // FAST, MODERATE, SLOW
  availableTime String?  // HOURS_PER_DAY
  salaryGoal  String?
  preferredCompany String?
  domainPreference String?
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, ARCHIVED
  isCurrent   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
}

model Task {
  id          String   @id @default(uuid())
  roadmapId   String
  title       String
  description String?
  type        String   // DAILY, WEEKLY, MONTHLY, PROJECT, CERTIFICATION, PLACEMENT, INTERVIEW
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, SKIPPED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  order       Int?
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  resources    String? // JSON array
  subtopics    String? // JSON array of subtopics for focused learning
  createdAt   DateTime @default(now())
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String      @id @default(uuid())
  userId    String
  title     String?
  category  String?     // CAREER, PLACEMENT, INTERVIEW, RESUME, LEARNING, GENERAL
  isArchived Boolean    @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  role      String   // USER, AI
  content   String
  metadata  String?  // JSON for additional context
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

model Interview {
  id             String   @id @default(uuid())
  userId         String
  type           String   // TECHNICAL, HR, CODING, MOCK
  role           String?
  company        String?
  status         String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  overallScore   Float?
  communicationScore Float?
  confidenceScore Float?
  technicalAccuracy Float?
  problemSolvingScore Float?
  strengths      String?  // JSON array
  weakAreas      String?  // JSON array
  improvementPlan String?
  questions      String?  // JSON array
  answers        String?  // JSON array
  feedback       String?
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // ROADMAP_UPDATED, SKILL_RECOMMENDED, MARKET_CHANGE, MILESTONE, READINESS_IMPROVED, INTERVIEW_PERFORMANCE
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LearningResource {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String?
  type        String   // COURSE, ARTICLE, VIDEO, BOOK, TUTORIAL
  skills      String?  // JSON array
  careerIds   String?  // JSON array
  difficulty  String?  // BEGINNER, INTERMEDIATE, ADVANCED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
